PORT=3000

# ─── Aegis Core ───────────────────────────────────────────────────────────────
# Base URL for the Aegis Core API (no trailing slash)
AEGIS_BASE_URL=https://aegis-dev.preprodcxr.co

# Country code → determines the Keycloak realm: puntored-{country}
# Used in the M2M token endpoint: POST /api/v1/auth/{country}/token
AEGIS_COUNTRY=co

# Service account credentials (client_id + client_secret from Keycloak / Aegis Admin)
# Sent as: Authorization: Basic base64(AEGIS_CLIENT_ID:AEGIS_CLIENT_SECRET)
AEGIS_CLIENT_ID=aegis-backend-test
AEGIS_CLIENT_SECRET=lCj0O3D1tov6yMwLxkrpRdKkmooszYxU

# ─── JWT validation ───────────────────────────────────────────────────────────
# Role required by GET /resource/admin
# Any role present in the Aegis JWT "roles" array is valid (e.g. aegis-admin, aegis-reader, ADMIN)
AEGIS_REQUIRED_ROLE=aegis-admin

# Optional: enforce a specific issuer when validating incoming JWTs.
# Leave empty to accept any issuer (useful across environments).
# The Aegis dev issuer is: https://aegis-dev.preprod
# AEGIS_TOKEN_ISSUER=
